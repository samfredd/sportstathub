# ─────────────────────────────────────────────────────────────────────────────
# Backend production environment — copy to /var/www/project/backend/.env
# Generate secrets: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=4000
HOST=0.0.0.0
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRATION=3600
CORS_ORIGIN=https://YOUR_DOMAIN
LOG_LEVEL=warn

# PostgreSQL — matches docker-compose.prod.yml
DATABASE_URL=postgres://project:CHANGE_ME_DB_PASSWORD@localhost:5432/me

# Redis — matches docker-compose.prod.yml
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://YOUR_DOMAIN/auth/google/callback

# API-Football
FOOTBALL_API_KEY=your-api-football-key

# Odds API
ODDS_API_KEY=

# Ollama — containerised LLM (resolved via internal Docker DNS)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Admin invite key
ADMIN_INVITE_KEY=CHANGE_ME_openssl_rand_hex_32

# OTP
REQUIRE_OTP=true

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_CALLBACK_URL=https://YOUR_DOMAIN/dashboard/subscription

# OddSwitch (internal — not public-facing)
ODDSWITCH_URL=http://localhost:8001
ODDSWITCH_API_KEY=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=no-reply@YOUR_DOMAIN
EMAIL_FROM_NAME=Your App Name

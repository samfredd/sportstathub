# ─────────────────────────────────────────────────────────────────────────────
# Production environment.
#
# This file lives next to docker-compose.prod.yml ON THE SERVER (e.g.
# /var/www/project/.env). Docker Compose reads it for ${VAR} substitution.
# Secrets stay on the server — they are NOT committed to git or shipped by CI.
# Copy this to .env and fill in every value.
#
# Generate secrets:  openssl rand -hex 32   (use -hex 64 for SECRET_KEY)
#
# NOT set here on purpose:
#   • NEXT_PUBLIC_API_URL — baked into the frontend image at build time by CI
#     as https://${DOMAIN}. Setting it here does nothing; only DOMAIN matters.
#   • Inter-service URLs (db, redis, oddswitch-api) — wired by Docker
#     networking in the compose file, not configured here.
# ─────────────────────────────────────────────────────────────────────────────

# Domain (no https://, no trailing slash)
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Container images
# Set IMAGE_NAMESPACE to your GitHub repo, for example: owner/repo
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=your-github-owner/your-repo
IMAGE_TAG=latest

# Database
# ⚠️ Postgres only applies this when it FIRST creates its data volume. On an
# existing deployment the volume keeps its original password — changing this
# value will NOT change the DB password, it will only break the backend's
# DATABASE_URL. Do not change it unless you also reset the postgres volume.
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_PASSWORD=CHANGE_ME

# Backend secrets
SECRET_KEY=CHANGE_ME
ADMIN_INVITE_KEY=CHANGE_ME

# API Keys
FOOTBALL_API_KEY=
SPORTS_API_KEY=
ODDS_API_KEY=

# NVIDIA AI (build.nvidia.com / NIM) — hosted LLM for AI match predictions
# Get an API key at: https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Google OAuth2 — required for "Sign in with Google"
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://${DOMAIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Billing — Paystack (leave blank to disable checkout/subscriptions)
# Test keys start sk_test_/pk_test_; live keys sk_live_/pk_live_.
# PAYSTACK_CALLBACK_URL is derived in compose as https://${DOMAIN}/dashboard/subscription.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# OTP verification (set to false to skip email OTP on register)
REQUIRE_OTP=true

# SMTP (leave SMTP_HOST blank to disable email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in every value
# Generate secrets: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Domain (no https://, no trailing slash)
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Container images
# Set IMAGE_NAMESPACE to your GitHub repo, for example: owner/repo
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=your-github-owner/your-repo
IMAGE_TAG=latest

# Database
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_PASSWORD=CHANGE_ME

# Backend secrets
SECRET_KEY=CHANGE_ME
ADMIN_INVITE_KEY=CHANGE_ME

# API Keys
FOOTBALL_API_KEY=
SPORTS_API_KEY=
ODDS_API_KEY=

# Google OAuth2 — required for "Sign in with Google"
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://${DOMAIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OTP verification (set to false to skip email OTP on register)
REQUIRE_OTP=true

# SMTP (leave SMTP_HOST blank to disable email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Ollama — containerised LLM for AI match predictions
# The backend reaches Ollama via internal Docker DNS name "ollama"
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b

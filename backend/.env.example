# Server
PORT=4000
HOST=localhost
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRATION=3600
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# PostgreSQL (matches docker-compose.yaml defaults)
DATABASE_URL=postgres://project:project123@localhost:5432/me

# Redis (matches docker-compose.yaml defaults)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Google OAuth2
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# API-Football — free tier: 100 requests/day
# Sign up at: https://dashboard.api-football.com
FOOTBALL_API_KEY=6bcaeb6832b682d5e149108a77377bc2

# The Odds API — free tier: 500 credits/month
# Sign up at: https://the-odds-api.com
ODDS_API_KEY=

# NVIDIA AI (build.nvidia.com / NIM) — hosted LLM for AI match predictions
# Get an API key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Admin invite key — required to use /auth/admin/register
# Set a strong random string (e.g. openssl rand -hex 32). Leave blank to disable admin self-registration.
ADMIN_INVITE_KEY=newadmin

# OTP verification — set to false to skip email verification on register (auto-verify + return JWT directly)
REQUIRE_OTP=true

# Paystack — use test keys locally; backend initializes and verifies transactions
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_CALLBACK_URL=http://localhost:3000/dashboard/subscription

# OddSwitch — booking code translation engine (Bet9ja ↔ SportyBet)
# Start with: ./oddswitch/run.sh
ODDSWITCH_URL=http://localhost:8001
# Optional API key (leave blank for local/internal use with no auth)
ODDSWITCH_API_KEY=

# SMTP (optional — leave SMTP_HOST blank to skip email sending)
# Recommended: Resend (https://resend.com) — reliable transactional email via its SMTP gateway.
#   1. Create an API key in the Resend dashboard (starts with "re_").
#   2. Add + verify your sending domain (DNS records) so EMAIL_FROM can use it.
#   3. SMTP_USER is the literal word "resend"; SMTP_PASS is the API key.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=SportStatHub
# Gmail alternative: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false
#   SMTP_USER=you@gmail.com SMTP_PASS=<16-char Google App Password>

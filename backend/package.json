    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
